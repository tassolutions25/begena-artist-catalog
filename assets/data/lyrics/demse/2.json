{
  "paragraphs": [
    {
      "text": "ከዘመዶቼ ተጣልቼ\nከወገኖቼም ተጣልቼ",
      "indent": 0
    },
    {
      "text": "የሚያስታርቀኝ ሰው አጥቼ\nተቃጥሬያለሁ ለሐሙስ",
      "indent": 24
    },
    {
      "text": "መድኃኔዓለም ድረስ\nቅዱስ ቅዱስ ቅዱስ",
      "indent": 0
    },
    {
      "text": "ጽላት ዘሙሴ ስልሽ\nየአክሱም ጽዮን ስልሽ",
      "indent": 24
    },
    {
      "text": "ወላዲተ አምላክ ስልሽ\nእመብርሃን ስልሽ\nበሠረገላ ሆነሽ",
      "indent": 0
    },
    {
      "text": "ሚካኤል ገብርኤልንም ይዘሽ\nይሸሻሉ አጋንንት አንቺን ሲያዩሽ",
      "indent": 24
    }
  ]
}